{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "lib": [
      "DOM",
      "ES2020"
    ]
  },
  "include": [
    "scripts/**/*.mjs"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
